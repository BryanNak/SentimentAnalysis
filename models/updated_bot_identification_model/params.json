{
  "feature_extraction": {
    "type": "FeatureUnion",
    "components": [
      {
        "name": "word_tfidf",
        "type": "TfidfVectorizer",
        "parameters": {
          "analyzer": "word",
          "ngram_range": [1, 2],
          "max_features": 50000,
          "min_df": 2,
          "max_df": 0.95,
          "sublinear_tf": true,
          "lowercase": true
        }
      },
      {
        "name": "char_tfidf",
        "type": "TfidfVectorizer",
        "parameters": {
          "analyzer": "char_wb",
          "ngram_range": [3, 5],
          "max_features": 50000,
          "min_df": 2,
          "sublinear_tf": true,
          "lowercase": true
        }
      }
    ]
  },
  "classifier": {
    "type": "XGBClassifier",
    "parameters": {
      "n_estimators": 1200,
      "max_depth": 13,
      "learning_rate": 0.035,
      "subsample": 0.85,
      "colsample_bytree": 0.55,
      "gamma": 0.1,
      "min_child_weight": 2,
      "reg_alpha": 0.3,
      "reg_lambda": 0.0,
      "scale_pos_weight": 2.5
    }
  }
}